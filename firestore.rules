rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - email: string (required)
    // - role: string (required, ['admin', 'client'])
    // - displayName: string (optional)
    //
    // Collection: sales
    // - date: string (required, date format)
    // - model: string (required)
    // - condition: string (required)
    // - platform: string (required)
    // - quantity: number (required)
    // - buy_price: number (required)
    // - sell_price: number (required)
    // - profit: number (required)
    // - userId: string (required)
    //
    // Collection: stock
    // - model: string (required)
    // - condition: string (required)
    // - quantity: number (required)
    // - buy_price: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "csmucza@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'client'];
    }

    function isValidSale(data) {
      return data.keys().hasAll(['date', 'model', 'condition', 'platform', 'quantity', 'buy_price', 'sell_price', 'profit', 'userId']) &&
             data.quantity is number && data.quantity > 0 &&
             data.buy_price is number &&
             data.sell_price is number &&
             data.userId == request.auth.uid;
    }

    function isValidStock(data) {
      return data.keys().hasAll(['model', 'condition', 'quantity', 'buy_price']) &&
             data.quantity is number &&
             data.buy_price is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'client' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /stock/{stockId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /market_prices/{priceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pending_sales/{pendingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
